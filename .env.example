# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# API server port (default 3001)
PORT=3001

# Google OAuth Client ID — needed for Google Meet + email notifications
# Setup: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Enable: Google Calendar API
# Type: Web application, add your domain to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
